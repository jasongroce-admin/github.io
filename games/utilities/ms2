<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>✨ Magic Screen PRO ✨</title>
    <style>
      :root { --accent: #66ccff; }
      body {
        background: radial-gradient(circle at top, rgba(102, 204, 255, 0.15), transparent 45%), #050814;
        margin: 0; padding: 0; font-family: system-ui, -apple-system, sans-serif; color: #e3dcff;
      }
      .header { background: rgba(11, 27, 48, 0.95); backdrop-filter: blur(12px); border-bottom: 1px solid #335;
        padding: 8px 16px; display: flex; align-items: center; gap: 12px; position: sticky; top: 0; z-index: 100;
        box-shadow: 0 4px 20px rgba(102, 204, 255, 0.15); }
      .header h1 { margin:0; font-size:1.4rem; background:linear-gradient(90deg,#66ccff,#ff66cc); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
      .btn { padding:6px 14px; background:#0b1b30; border:1px solid #446; border-radius:8px; color:#e3dcff; cursor:pointer; transition:all .2s; }
      .btn:hover { background:#112b44; border-color:var(--accent); box-shadow:0 0 12px rgba(102,204,255,0.4); }
      .main { display:flex; height:calc(100vh - 57px); }
      .sidebar, .inspector { width:260px; background:#0b1b30f2; border-right:1px solid #335; padding:12px; overflow-y:auto; display:flex; flex-direction:column; gap:16px; }
      .inspector { border-right:none; border-left:1px solid #335; }
      .panel { background:linear-gradient(180deg,#101b36,#0a1023); border:1px solid #335; border-radius:12px; padding:12px; }
      .panel h3 { margin:0 0 10px; font-size:1rem; display:flex; align-items:center; gap:6px; cursor:pointer; }
      .control { display:flex; align-items:center; gap:8px; margin-bottom:12px; }
      .control label { flex:1; font-size:0.85rem; white-space:nowrap; }
      .control input[type="range"] { flex:2; }
      .control input[type="number"] { width:68px; background:#112b44; border:1px solid #446; color:#e3dcff; padding:4px 8px; border-radius:6px; }
      .tools-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(70px,1fr)); gap:8px; }
      .tool-btn { display:flex; flex-direction:column; align-items:center; gap:4px; padding:8px; background:#112b44; border:2px solid transparent; border-radius:10px; font-size:0.75rem; transition:all .2s; }
      .tool-btn.active { border-color:var(--accent); background:#1e3a55; box-shadow:0 0 15px rgba(102,204,255,0.5); }
      .canvas-container { flex:1; display:flex; flex-direction:column; background:#070b14; padding:12px; gap:8px; }
      .canvasWrap { flex:1; background:#070b14; border:2px solid #335; border-radius:16px; overflow:hidden; position:relative; box-shadow:0 0 40px rgba(102,204,255,0.2); }
      canvas { width:100%; height:100%; display:block; background:#080b18; touch-action:none; }
      .preview { width:100%; height:120px; background:#112b44; border-radius:10px; margin-bottom:12px; border:1px solid #446; overflow:hidden; }
      .hint { font-size:0.75rem; opacity:0.7; }
      .tweak-grid { display:grid; gap:10px; }
      .collapsed .panel-content { display:none; }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>✨ Magic Screen PRO ✨</h1>
      <div style="flex:1"></div>
      <button class="btn" id="newBtn">🆕 New</button>
      <button class="btn" id="undoBtn">↩️ Undo</button>
      <button class="btn" id="redoBtn">↪️ Redo</button>
      <button class="btn" id="clearBtn">🗑️ Clear</button>
      <button class="btn" id="saveBtn">💾 Save PNG</button>
      <button class="btn magic-btn" id="magicBtn">🪄 Random Magic</button>
      <button class="btn" id="fullscreenBtn">⛶ Full</button>
    </div>

    <div class="main">
      <!-- LEFT SIDEBAR -->
      <div class="sidebar">
        <div class="panel">
          <h3>🖌️ Tools</h3>
          <div class="tools-grid">
            <button class="tool-btn active" data-tool="brush">🖌️ Brush</button>
            <button class="tool-btn" data-tool="eraser">🧼 Eraser</button>
          </div>
        </div>

        <div class="panel">
          <h3>🎨 Brush Settings</h3>
          <div class="control"><label>Size</label><input id="size" type="range" min="1" max="140" value="14"><input id="sizeNum" type="number" value="14"></div>
          <div class="control"><label>Opacity</label><input id="alpha" type="range" min="0.05" max="1" step="0.01" value="1"><input id="alphaNum" type="number" value="1" step="0.01"></div>
          <div class="control"><label>Flow</label><input id="flow" type="range" min="0.1" max="1" step="0.05" value="1"><input id="flowNum" type="number" value="1" step="0.05"></div>
          <div class="control"><label>Glow</label><input id="glow" type="range" min="0" max="100" value="28"><input id="glowNum" type="number" value="28"></div>
        </div>

        <div class="panel">
          <h3>🌈 Effect</h3>
          <select id="effect" style="width:100%;padding:10px;border-radius:8px;background:#112b44;border:1px solid #446;color:#e3dcff;">
            <option value="neon">Neon Glow</option>
            <option value="rainbow">Rainbow Flow</option>
            <option value="spark">Spark Burst</option>
            <option value="fire">Dragon Fire</option>
            <option value="electric">Electric Arc</option>
            <option value="velvet">Velvet Ink</option>
            <option value="comet">Comet Trail</option>
            <option value="glitter">Stardust Glitter</option>
            <option value="prism">Prism Split</option>
            <option value="smoke">Mystic Smoke</option>
            <option value="galaxy">Cosmic Galaxy</option>
            <option value="inkbleed">Ink Bleed</option>
            <option value="laser">Laser Beam</option>
          </select>
        </div>
      </div>

      <!-- CANVAS -->
      <div class="canvas-container">
        <div class="canvasWrap"><canvas id="board"></canvas></div>
        <div class="hint" style="text-align:center;margin-top:6px;">Drag to draw • Shift = straight line • Pressure sensitive</div>
      </div>

      <!-- RIGHT INSPECTOR -->
      <div class="inspector">

        <!-- Preview -->
        <div class="panel">
          <h3>🔮 Live Preview</h3>
          <div class="preview"><canvas id="preview" width="240" height="110"></canvas></div>
        </div>

        <!-- Color -->
        <div class="panel">
          <h3>🌟 Color</h3>
          <div class="control"><label>Base Color</label><input id="color" type="color" value="#66ccff" style="width:60px;height:34px;border:none;cursor:pointer;"></div>
          <div class="control"><label>Hue Shift</label><input id="hueShift" type="range" min="0" max="360" value="0"><input id="hueShiftNum" type="number" value="0"></div>
        </div>

        <!-- ENHANCED SYMMETRY -->
        <div class="panel">
          <h3>✨ Symmetry</h3>
          <select id="symmetry" style="width:100%;padding:10px;border-radius:8px;background:#112b44;border:1px solid #446;color:#e3dcff;">
            <option value="none">None</option>
            <option value="mirror-x">Mirror X</option>
            <option value="mirror-y">Mirror Y</option>
            <option value="quad">Quad Mirror</option>
            <option value="radial-6">Radial 6</option>
            <option value="radial-8">Radial 8</option>
            <option value="radial-12">Radial 12</option>
            <option value="kaleido-6">Kaleido 6</option>
            <option value="kaleido-8">Kaleido 8</option>
          </select>
          
          <div class="control" style="margin-top:12px">
            <label>Rotation Offset</label>
            <input id="rotOffset" type="range" min="0" max="360" value="0">
            <input id="rotOffsetNum" type="number" value="0" style="width:55px">
          </div>
          <div class="control">
            <label>Auto-Spin Speed</label>
            <input id="rotSpeed" type="range" min="0" max="8" step="0.1" value="0">
            <input id="rotSpeedNum" type="number" value="0" step="0.1" style="width:55px">
          </div>
          <div class="control">
            <label>Center X %</label>
            <input id="symCenterX" type="range" min="20" max="80" value="50">
            <input id="symCenterXNum" type="number" value="50" style="width:55px">
          </div>
          <div class="control">
            <label>Center Y %</label>
            <input id="symCenterY" type="range" min="20" max="80" value="50">
            <input id="symCenterYNum" type="number" value="50" style="width:55px">
          </div>
        </div>

        <!-- ADVANCED EFFECTS TWEAKS (dynamic) -->
        <div class="panel" id="advancedPanel">
          <h3 onclick="this.parentElement.classList.toggle('collapsed')">⚙️ Advanced Effect Tweaks <span style="margin-left:auto;font-size:0.9rem">▼</span></h3>
          <div class="panel-content tweak-grid" id="tweakContent"></div>
        </div>

        <!-- Canvas -->
        <div class="panel">
          <h3>🎥 Canvas</h3>
          <div class="control"><label>Fade (sec)</label><input id="fade" type="range" min="0" max="30" value="0"><input id="fadeNum" type="number" value="0"></div>
          <div class="control"><label>Performance</label>
            <select id="perfMode" style="flex:2;padding:4px;background:#112b44;border:1px solid #446;color:#e3dcff;">
              <option value="high">High Quality</option>
              <option value="med" selected>Balanced</option>
              <option value="low">Fast Mode</option>
            </select>
          </div>
          <button id="resetSettings" class="btn" style="width:100%;margin-top:8px;">Reset Everything</button>
        </div>
      </div>
    </div>

    <script>
      const canvas = document.getElementById('board');
      const ctx = canvas.getContext('2d');
      const previewCanvas = document.getElementById('preview');
      const pctx = previewCanvas.getContext('2d');

      let history = [], redoStack = [];
      let drawing = false, lastPos = null;
      let particles = [];
      let currentAngle = 0;

      // Global performance multiplier
      let perfMultiplier = 1; // 1 = high, 0.6 = med, 0.3 = low

      let settings = {
        size:14, alpha:1, flow:1, glow:28,
        hueShift:0, color:'#66ccff', effect:'neon',
        symmetry:'none', fade:0,
        rotSpeed:0, rotOffset:0,
        symCenterX:50, symCenterY:50,
        // Advanced per-effect tweaks (defaults)
        neonLayers:4,
        particleDensity:1,
        jitter:0,
        bleedAmount:12,
        electricJagged:8,
        cometTrailLength:18
      };

      class Particle {
        constructor(x, y, vx, vy, life, color) {
          this.x = x; this.y = y; this.vx = vx; this.vy = vy;
          this.life = life; this.maxLife = life; this.color = color;
        }
        update() { this.x += this.vx; this.y += this.vy; this.life--; }
        draw() {
          const a = this.life / this.maxLife;
          ctx.globalAlpha = a * 0.9;
          ctx.fillStyle = this.color;
          const sz = Math.max(2, 4 * (this.life / this.maxLife));
          ctx.fillRect(this.x - sz/2, this.y - sz/2, sz, sz);
        }
      }

      function addParticles(x, y, baseCount, effect) {
        const count = Math.floor(baseCount * settings.particleDensity * perfMultiplier);
        if (particles.length > 180) return; // hard global cap for performance
        for (let i = 0; i < count; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 3.5;
          let vx = Math.cos(angle) * speed;
          let vy = Math.sin(angle) * speed - (effect === 'fire' || effect === 'smoke' ? 1.2 : 0);
          let col = '#fff';
          if (effect === 'fire') col = `hsl(${15+Math.random()*45},100%,${55+Math.random()*40}%)`;
          if (effect === 'glitter' || effect === 'spark') col = `hsl(${Math.random()*360},100%,98%)`;
          if (effect === 'smoke') col = `hsla(210,15%,${65+Math.random()*30}%,0.7)`;
          if (effect === 'galaxy') col = `hsl(${190 + Math.random()*170},85%,75%)`;
          particles.push(new Particle(x, y, vx, vy, 22 + Math.random()*38, col));
        }
      }

      function updateParticles() {
        for (let i = particles.length-1; i >= 0; i--) {
          const p = particles[i];
          p.update();
          if (p.life <= 0) particles.splice(i,1);
          else p.draw();
        }
        ctx.globalAlpha = 1;
      }

      function resize() {
        const rect = canvas.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);
      }

      function saveState() {
        history.push(ctx.getImageData(0, 0, canvas.width, canvas.height));
        if (history.length > 25) history.shift();
        redoStack = [];
      }

      function getSymmetryPoints(x, y) {
        const w = canvas.getBoundingClientRect().width;
        const h = canvas.getBoundingClientRect().height;
        const cx = w * (settings.symCenterX / 100);
        const cy = h * (settings.symCenterY / 100);
        let pts = [[x, y]];

        const sym = settings.symmetry;
        const rot = (settings.rotOffset + currentAngle) * Math.PI / 180;

        if (sym === 'mirror-x') pts.push([w - x, y]);
        else if (sym === 'mirror-y') pts.push([x, h - y]);
        else if (sym === 'quad') pts.push([w-x,y],[x,h-y],[w-x,h-y]);
        else if (sym.startsWith('radial') || sym.startsWith('kaleido')) {
          const count = sym.includes('12') ? 12 : sym.includes('8') ? 8 : 6;
          const dx = x - cx;
          const dy = y - cy;
          for (let i = 1; i < count; i++) {
            const a = (Math.PI * 2 / count) * i + rot;
            const rx = dx * Math.cos(a) - dy * Math.sin(a);
            const ry = dx * Math.sin(a) + dy * Math.cos(a);
            pts.push([cx + rx, cy + ry]);
            if (sym.startsWith('kaleido')) pts.push([cx - rx, cy + ry]);
          }
        }
        return pts;
      }

      function drawStroke(from, to, effect) {
        const symFrom = getSymmetryPoints(from.x, from.y);
        const symTo = getSymmetryPoints(to.x, to.y);

        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.shadowColor = settings.color;

        symFrom.forEach((p1, i) => {
          const p2 = symTo[i % symTo.length];
          const baseWidth = settings.size * settings.flow;

          if (effect === 'neon') {
            const layers = Math.max(2, Math.floor(settings.neonLayers * perfMultiplier));
            for (let l = layers; l >= 0; l--) {
              ctx.shadowBlur = settings.glow + l * 14;
              ctx.globalAlpha = settings.alpha * (1 - l * 0.22);
              ctx.lineWidth = baseWidth + l * 2;
              ctx.strokeStyle = settings.color;
              ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            }
          } 
          else if (effect === 'rainbow' || effect === 'prism') {
            const hueBase = (Date.now() / 18 + settings.hueShift) % 360;
            ctx.strokeStyle = `hsla(${hueBase + (effect==='prism'?i*35:0)}, 98%, 68%, ${settings.alpha})`;
            ctx.shadowBlur = settings.glow;
            ctx.lineWidth = baseWidth;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
          } 
          else if (effect === 'fire') {
            ctx.shadowBlur = settings.glow + 10;
            ctx.strokeStyle = `hsl(${12 + Math.random()*38},100%,68%)`;
            ctx.lineWidth = baseWidth;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            if (Math.random() > 0.3) addParticles((p1[0]+p2[0])/2, (p1[1]+p2[1])/2 - 12, 4, 'fire');
          } 
          else if (effect === 'electric') {
            ctx.shadowBlur = 45;
            ctx.shadowColor = '#bbffff';
            ctx.strokeStyle = '#ddffff';
            ctx.lineWidth = baseWidth * 0.65;
            const dash = settings.electricJagged;
            ctx.setLineDash([dash, dash*1.8]);
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            ctx.setLineDash([]);
            if (Math.random() > 0.4) addParticles((p1[0]+p2[0])/2, (p1[1]+p2[1])/2, 3, 'spark');
          } 
          else if (effect === 'velvet') {
            ctx.shadowBlur = 12;
            ctx.globalAlpha = settings.alpha * 0.9;
            ctx.lineWidth = baseWidth * 1.75;
            ctx.strokeStyle = settings.color;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
          } 
          else if (effect === 'comet') {
            ctx.globalAlpha = 0.85;
            ctx.shadowBlur = settings.glow;
            ctx.strokeStyle = settings.color;
            ctx.lineWidth = baseWidth;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            addParticles(p2[0], p2[1], settings.cometTrailLength, 'comet');
          } 
          else if (effect === 'glitter' || effect === 'spark') {
            ctx.shadowBlur = 22;
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = baseWidth * 0.8;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            addParticles(p2[0], p2[1], effect==='glitter'?9:5, effect);
          } 
          else if (effect === 'laser') {
            ctx.shadowBlur = 55;
            ctx.shadowColor = '#00ffff';
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = baseWidth * 0.55;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
          } 
          else if (effect === 'galaxy') {
            const hue = (Date.now()/35 + settings.hueShift) % 360;
            ctx.strokeStyle = `hsla(${hue},85%,72%,${settings.alpha})`;
            ctx.shadowBlur = settings.glow;
            ctx.lineWidth = baseWidth;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
            if (Math.random() > 0.55) addParticles(p2[0], p2[1], 3, 'galaxy');
          } 
          else if (effect === 'inkbleed') {
            ctx.shadowBlur = 32;
            ctx.globalAlpha = settings.alpha * 0.75;
            ctx.strokeStyle = settings.color;
            ctx.lineWidth = baseWidth * (1 + settings.bleedAmount / 20);
            const mx = (p1[0] + p2[0])/2 + (Math.random()-0.5) * settings.bleedAmount;
            const my = (p1[1] + p2[1])/2 + (Math.random()-0.5) * settings.bleedAmount;
            ctx.beginPath();
            ctx.moveTo(p1[0],p1[1]);
            ctx.quadraticCurveTo(mx, my, p2[0], p2[1]);
            ctx.stroke();
          } 
          else {
            ctx.strokeStyle = settings.color;
            ctx.lineWidth = baseWidth;
            ctx.shadowBlur = settings.glow;
            ctx.beginPath(); ctx.moveTo(p1[0],p1[1]); ctx.lineTo(p2[0],p2[1]); ctx.stroke();
          }
        });

        ctx.globalAlpha = 1;
        ctx.shadowBlur = 0;
        ctx.setLineDash([]);
      }

      function pointerDown(e) {
        drawing = true;
        const rect = canvas.getBoundingClientRect();
        lastPos = { x: e.clientX - rect.left, y: e.clientY - rect.top };
        saveState();
      }

      function pointerMove(e) {
        if (!drawing || !lastPos) return;
        const rect = canvas.getBoundingClientRect();
        const pos = { x: e.clientX - rect.left, y: e.clientY - rect.top };

        const pressure = e.pressure || 1;
        ctx.lineWidth = settings.size * pressure * settings.flow;

        drawStroke(lastPos, pos, settings.effect);

        if (['spark','glitter','comet','fire','smoke','galaxy'].includes(settings.effect)) updateParticles();

        lastPos = pos;
      }

      function pointerUp() {
        drawing = false;
        lastPos = null;
        particles = [];
      }

      function updatePreview() {
        pctx.fillStyle = '#112b44';
        pctx.fillRect(0,0,previewCanvas.width,previewCanvas.height);
        pctx.shadowBlur = 24;
        pctx.shadowColor = settings.color;
        pctx.lineWidth = 22;
        pctx.strokeStyle = settings.color;

        if (settings.effect === 'rainbow') {
          const h = (Date.now()/22) % 360;
          pctx.strokeStyle = `hsl(${h},95%,66%)`;
        }
        if (settings.effect === 'fire') pctx.strokeStyle = '#ff9900';

        pctx.beginPath();
        pctx.moveTo(35,58);
        pctx.quadraticCurveTo(88,22,195,68);
        pctx.stroke();
      }

      function tickFade() {
        if (settings.fade <= 0) return;
        ctx.save();
        ctx.fillStyle = `rgba(8,11,24,${1/(settings.fade*62)})`;
        ctx.fillRect(0,0,canvas.width,canvas.height);
        ctx.restore();
      }

      function animate() {
        tickFade();
        currentAngle += settings.rotSpeed * 0.9; // smooth auto-spin
        if (particles.length) updateParticles();
        requestAnimationFrame(animate);
      }

      // === DYNAMIC ADVANCED TWEAKS PANEL ===
      function buildTweakPanel() {
        const container = document.getElementById('tweakContent');
        container.innerHTML = '';

        const effect = settings.effect;

        let html = `<div class="control"><label>Particle Density</label><input id="tweakParticle" type="range" min="0.2" max="2.5" step="0.1" value="${settings.particleDensity}"><input id="tweakParticleNum" type="number" value="${settings.particleDensity}" step="0.1"></div>`;

        if (effect === 'neon') {
          html += `<div class="control"><label>Neon Layers</label><input id="tweakNeonLayers" type="range" min="2" max="7" value="${settings.neonLayers}"><input id="tweakNeonLayersNum" type="number" value="${settings.neonLayers}"></div>`;
        }
        if (effect === 'inkbleed') {
          html += `<div class="control"><label>Bleed Spread</label><input id="tweakBleed" type="range" min="4" max="40" value="${settings.bleedAmount}"><input id="tweakBleedNum" type="number" value="${settings.bleedAmount}"></div>`;
        }
        if (effect === 'electric') {
          html += `<div class="control"><label>Jaggedness</label><input id="tweakJagged" type="range" min="3" max="18" value="${settings.electricJagged}"><input id="tweakJaggedNum" type="number" value="${settings.electricJagged}"></div>`;
        }
        if (effect === 'comet') {
          html += `<div class="control"><label>Trail Length</label><input id="tweakTrail" type="range" min="6" max="32" value="${settings.cometTrailLength}"><input id="tweakTrailNum" type="number" value="${settings.cometTrailLength}"></div>`;
        }

        container.innerHTML = html;

        // Attach listeners
        const particleSlider = document.getElementById('tweakParticle');
        const particleNum = document.getElementById('tweakParticleNum');
        if (particleSlider) {
          particleSlider.oninput = () => { settings.particleDensity = parseFloat(particleSlider.value); particleNum.value = settings.particleDensity; };
          particleNum.oninput = () => { settings.particleDensity = parseFloat(particleNum.value); particleSlider.value = settings.particleDensity; };
        }

        if (effect === 'neon') {
          const lSlider = document.getElementById('tweakNeonLayers');
          const lNum = document.getElementById('tweakNeonLayersNum');
          lSlider.oninput = () => { settings.neonLayers = parseFloat(lSlider.value); lNum.value = settings.neonLayers; };
          lNum.oninput = () => { settings.neonLayers = parseFloat(lNum.value); lSlider.value = settings.neonLayers; };
        }
        if (effect === 'inkbleed') {
          const bSlider = document.getElementById('tweakBleed');
          const bNum = document.getElementById('tweakBleedNum');
          bSlider.oninput = () => { settings.bleedAmount = parseFloat(bSlider.value); bNum.value = settings.bleedAmount; };
          bNum.oninput = () => { settings.bleedAmount = parseFloat(bNum.value); bSlider.value = settings.bleedAmount; };
        }
        if (effect === 'electric') {
          const jSlider = document.getElementById('tweakJagged');
          const jNum = document.getElementById('tweakJaggedNum');
          jSlider.oninput = () => { settings.electricJagged = parseFloat(jSlider.value); jNum.value = settings.electricJagged; };
          jNum.oninput = () => { settings.electricJagged = parseFloat(jNum.value); jSlider.value = settings.electricJagged; };
        }
        if (effect === 'comet') {
          const tSlider = document.getElementById('tweakTrail');
          const tNum = document.getElementById('tweakTrailNum');
          tSlider.oninput = () => { settings.cometTrailLength = parseFloat(tSlider.value); tNum.value = settings.cometTrailLength; };
          tNum.oninput = () => { settings.cometTrailLength = parseFloat(tNum.value); tSlider.value = settings.cometTrailLength; };
        }
      }

      function attachUI() {
        // Basic controls
        const sliders = ['size','alpha','flow','glow','hueShift','fade','rotSpeed','rotOffset','symCenterX','symCenterY'];
        sliders.forEach(id => {
          const s = document.getElementById(id);
          const n = document.getElementById(id + 'Num');
          if (s) s.addEventListener('input', () => {
            settings[id] = parseFloat(s.value);
            if (n) n.value = settings[id];
            if (['rotOffset','rotSpeed'].includes(id)) currentAngle = settings.rotOffset; // instant feedback
            if (id === 'glow' || id === 'size') updatePreview();
          });
          if (n) n.addEventListener('input', () => {
            settings[id] = parseFloat(n.value);
            if (s) s.value = settings[id];
          });
        });

        document.getElementById('color').addEventListener('input', e => { settings.color = e.target.value; updatePreview(); });
        document.getElementById('effect').addEventListener('change', e => {
          settings.effect = e.target.value;
          buildTweakPanel();
          updatePreview();
        });
        document.getElementById('perfMode').addEventListener('change', e => {
          const m = e.target.value;
          perfMultiplier = m === 'high' ? 1 : m === 'med' ? 0.65 : 0.3;
        });

        // Buttons
        document.getElementById('undoBtn').onclick = () => { if (history.length > 1) { redoStack.push(history.pop()); ctx.putImageData(history[history.length-1],0,0); }};
        document.getElementById('redoBtn').onclick = () => { if (redoStack.length) { history.push(redoStack.pop()); ctx.putImageData(history[history.length-1],0,0); }};
        document.getElementById('clearBtn').onclick = () => { ctx.clearRect(0,0,canvas.width,canvas.height); saveState(); };
        document.getElementById('saveBtn').onclick = () => {
          const a = document.createElement('a');
          a.download = `magic-pro-${Date.now()}.png`;
          a.href = canvas.toDataURL('image/png');
          a.click();
        };
        document.getElementById('magicBtn').onclick = () => {
          const opts = Array.from(document.getElementById('effect').options).map(o => o.value);
          settings.effect = opts[Math.floor(Math.random()*opts.length)];
          document.getElementById('effect').value = settings.effect;
          buildTweakPanel();
          settings.glow = 22 + Math.random()*55;
          updatePreview();
        };
        document.getElementById('resetSettings').onclick = () => {
          settings = {size:14,alpha:1,flow:1,glow:28,hueShift:0,color:'#66ccff',effect:'neon',symmetry:'none',fade:0,rotSpeed:0,rotOffset:0,symCenterX:50,symCenterY:50,neonLayers:4,particleDensity:1,jitter:0,bleedAmount:12,electricJagged:8,cometTrailLength:18};
          document.getElementById('effect').value = 'neon';
          document.getElementById('perfMode').value = 'med';
          perfMultiplier = 0.65;
          sliders.forEach(id => {
            const s = document.getElementById(id); const n = document.getElementById(id+'Num');
            if (s) s.value = settings[id]; if (n) n.value = settings[id];
          });
          buildTweakPanel();
          updatePreview();
        };

        // Tool buttons
        document.querySelectorAll('.tool-btn').forEach(b => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.tool-btn').forEach(btn => btn.classList.remove('active'));
            b.classList.add('active');
          });
        });
      }

      function init() {
        resize();
        window.addEventListener('resize', resize);

        canvas.addEventListener('pointerdown', pointerDown);
        canvas.addEventListener('pointermove', pointerMove);
        canvas.addEventListener('pointerup', pointerUp);
        canvas.addEventListener('pointerleave', pointerUp);

        attachUI();
        buildTweakPanel();        // initial tweaks
        updatePreview();
        saveState();
        animate();

        console.log('%c✅ Magic Screen PRO v2 – Advanced Tweaks + Enhanced Symmetry loaded (performance optimized)', 'color:#66ccff;font-weight:bold');
      }

      init();
    </script>
  </body>
</html>
